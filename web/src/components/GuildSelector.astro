---
interface Props {
  guilds: Array<{
    id: string;
    name: string;
    icon: string | null;
    bot_in_guild: boolean;
  }>;
  clientId: string;
}

const { guilds, clientId } = Astro.props;

const getInviteLink = (guildId: string) => {
  return `https://discord.com/oauth2/authorize?client_id=${clientId}&scope=bot+applications.commands&permissions=8&guild_id=${guildId}`;
};

const botInGuilds = guilds.filter(g => g.bot_in_guild);
const availableGuilds = guilds.filter(g => !g.bot_in_guild);
---

<div class="guild-selector">
  <!-- BOT IST BEREITS VORHANDEN -->
  {botInGuilds.length > 0 && (
    <div class="guild-section">
      <h3>✅ Bot ist bereits auf diesen Servern</h3>
      <div class="guilds-grid">
        {botInGuilds.map(guild => (
          <div class="guild-card already-member">
            {guild.icon && <img src={guild.icon} alt={guild.name} class="guild-icon" />}
            {!guild.icon && <div class="guild-icon-placeholder">🎮</div>}
            <div class="guild-info">
              <div class="guild-name">{guild.name}</div>
              <div class="guild-status">Bot aktiv</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- VERFÜGBARE SERVER ZUM EINLADEN -->
  {availableGuilds.length > 0 && (
    <div class="guild-section">
      <h3>➕ Bot zu diesen Servern hinzufügen</h3>
      <div class="guilds-grid">
        {availableGuilds.map(guild => (
          <a href={getInviteLink(guild.id)} target="_blank" rel="noopener noreferrer" class="guild-card invite-card">
            {guild.icon && <img src={guild.icon} alt={guild.name} class="guild-icon" />}
            {!guild.icon && <div class="guild-icon-placeholder">🎮</div>}
            <div class="guild-info">
              <div class="guild-name">{guild.name}</div>
              <div class="guild-status">Klick zum einladen</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {guilds.length === 0 && (
    <div class="guild-empty">
      <p>Du hast keine Server gefunden, auf denen du Admin bist.</p>
    </div>
  )}
</div>

<style>
  .guild-selector {
    margin: 20px 0;
  }

  .guild-section {
    margin-bottom: 30px;
  }

  .guild-section h3 {
    margin-bottom: 15px;
    color: #e2e8f0;
    font-size: 16px;
    font-weight: 600;
  }

  .guilds-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }

  .guild-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 8px;
    transition: all 0.2s ease;
    text-decoration: none;
    cursor: pointer;
  }

  .guild-card:hover {
    border-color: #64748b;
    background: #0f172a;
  }

  .invite-card:hover {
    border-color: #10b981;
    background: rgba(16, 185, 129, 0.05);
  }

  .already-member {
    cursor: default;
    opacity: 0.7;
  }

  .already-member:hover {
    border-color: #334155;
    background: #1e293b;
  }

  .guild-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .guild-icon-placeholder {
    width: 40px;
    height: 40px;
    min-width: 40px;
    background: #334155;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .guild-info {
    flex: 1;
    min-width: 0;
  }

  .guild-name {
    color: #e2e8f0;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .guild-status {
    color: #94a3b8;
    font-size: 12px;
    margin-top: 2px;
  }

  .guild-empty {
    padding: 30px;
    text-align: center;
    color: #94a3b8;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 8px;
  }

  @media (max-width: 768px) {
    .guilds-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }
  }
</style>
