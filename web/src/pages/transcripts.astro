---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ModBot Dragon · Transcripts" pageTitle="Transcripts">
  <div class="main">
    <header class="topbar">
      <div class="topbar-title">Dashboard <span class="topbar-sep">›</span> <span class="crumb-active">Transcripts</span></div>
    </header>

    <main class="content">
      <div class="card">
        <div class="card-header">
          <div>Alle Transcripts</div>
        </div>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th># Ticket</th>
                <th>User</th>
                <th>Kategorie</th>
                <th>Status</th>
                <th>Erstellt</th>
              </tr>
            </thead>
            <tbody id="transcripts-body">
              Lade Transcripts...
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</Layout>