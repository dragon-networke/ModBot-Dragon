---
// src/pages/auth/logout.astro
Astro.cookies.delete('session', { path: '/' });
Astro.cookies.delete('selectedGuild', { path: '/' });

// Optional: Cache-Control, um Caching-Probleme zu vermeiden
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');

return Astro.redirect('/login');
---
