const code = Astro.url.searchParams.get('code');
if (!code) {
  return Astro.redirect('/login?error=no_code');
}

// ====================== DYNAMISCHE REDIRECT URI ======================
const getRedirectUri = (): string => {
  if (import.meta.env.PUBLIC_DISCORD_REDIRECT_URI) {
    return import.meta.env.PUBLIC_DISCORD_REDIRECT_URI;
  }

  if (import.meta.env.VERCEL_URL || import.meta.env.VERCEL_BRANCH_URL) {
    const vercelHost = import.meta.env.VERCEL_URL || import.meta.env.VERCEL_BRANCH_URL;
    return `https://${vercelHost}/auth/callback`;
  }

  const protocol = Astro.url.protocol;
  const host = Astro.url.host;
  return `${protocol}//${host}/auth/callback`;
};

const REDIRECT_URI = getRedirectUri();

console.log('[Auth] Verwendete Redirect URI →', REDIRECT_URI);
// =====================================================================

const CLIENT_ID     = import.meta.env.DISCORD_CLIENT_ID || import.meta.env.PUBLIC_DISCORD_CLIENT_ID || '';
const CLIENT_SECRET = import.meta.env.DISCORD_CLIENT_SECRET || '';

if (!CLIENT_ID || !CLIENT_SECRET) {
  console.error('[Auth] Fehlende Discord Credentials');
  return Astro.redirect('/login?error=missing_credentials');
}

try {
  // 1. Access Token holen
  const tokenRes = await fetch('https://discord.com/api/oauth2/token', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: new URLSearchParams({
      client_id:     CLIENT_ID,
      client_secret: CLIENT_SECRET,
      grant_type:    'authorization_code',
      code:          code,
      redirect_uri:  REDIRECT_URI,
    }),
  });

  if (!tokenRes.ok) {
    const errText = await tokenRes.text();
    console.error('[Auth] Token-Fehler:', errText);
    return Astro.redirect('/login?error=oauth_failed');
  }

  const tokenData   = await tokenRes.json();
  const accessToken = tokenData.access_token;

  // 2. User-Info holen
  const userRes = await fetch('https://discord.com/api/users/@me', {
    headers: { Authorization: `Bearer ${accessToken}` },
  });
  if (!userRes.ok) return Astro.redirect('/login?error=oauth_failed');
  const user = await userRes.json();

  // 3. Guilds holen (nur für Info)
  const guildsRes = await fetch('https://discord.com/api/users/@me/guilds', {
    headers: { Authorization: `Bearer ${accessToken}` },
  });
  const guilds = guildsRes.ok ? await guildsRes.json() : [];

  console.log('[Auth] User:', user.username, '| Guilds:', guilds.length);

  // 4. Session setzen
  const sessionData = {
    user: {
      id:       user.id,
      username: user.username,
      avatar:   user.avatar,
      discriminator: user.discriminator || '0',
    },
    accessToken,
    expires: Date.now() + 1000 * 60 * 60 * 24, // 24 Stunden
  };

  const sessionBase64 = Buffer.from(JSON.stringify(sessionData)).toString('base64');

  Astro.cookies.set('session', sessionBase64, {
    path:     '/',
    httpOnly: true,
    secure:   import.meta.env.PROD,
    maxAge:   60 * 60 * 24,
    sameSite: 'lax',
  });

  // WICHTIG: Nach Login immer zur Server-Auswahl
  return Astro.redirect('/guild');

} catch (e: any) {
  console.error('[Auth] Unerwarteter Fehler:', e.message);
  return Astro.redirect('/login?error=oauth_failed');
}
