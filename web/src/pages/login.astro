---
import '../styles/global.css';

// Sehr strenge Session-Prüfung – nur bei wirklich gültiger Session weiterleiten
const sessionCookie = Astro.cookies.get('session')?.value;
let shouldRedirect = false;

if (sessionCookie) {
  try {
    const data = JSON.parse(Buffer.from(sessionCookie, 'base64').toString('utf-8'));
    
    // Nur wenn die Session wirklich gültig und nicht abgelaufen ist
    if (data && data.user && data.expires && Date.now() < data.expires) {
      shouldRedirect = true;
    }
  } catch (e) {
    // Ungültiges Cookie → Login-Seite anzeigen
    console.log('Ungültiges Session-Cookie erkannt');
  }
}

// Nur bei wirklich gültiger Session zur Server-Auswahl weiterleiten
if (shouldRedirect) {
  return Astro.redirect('/guild');
}

const CLIENT_ID    = import.meta.env.PUBLIC_DISCORD_CLIENT_ID || '';
const REDIRECT_URI = import.meta.env.PUBLIC_DISCORD_REDIRECT_URI || 'http://localhost:4321/auth/callback';
const error        = Astro.url.searchParams.get('error');

const oauthUrl = `https://discord.com/oauth2/authorize?client_id=${CLIENT_ID}&redirect_uri=${encodeURIComponent(REDIRECT_URI)}&response_type=code&scope=identify+guilds`;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ModBot Dragon · Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    /* Dein bisheriges Styling bleibt unverändert */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #060709;
      background-image: linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      color: #f1f5f9;
      font-family: 'Outfit', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .card {
      background: #0f1117;
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 20px;
      padding: 56px 48px;
      max-width: 440px;
      width: 100%;
      text-align: center;
      animation: fadeUp 0.4s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .dragon-logo {
      width: 220px;
      height: auto;
      margin: 0 auto 24px;
      filter: drop-shadow(0 0 35px rgba(239, 68, 68, 0.6));
    }

    h1 {
      font-size: 28px;
      font-weight: 800;
      margin-bottom: 6px;
    }

    .sub {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #3b82f6;
      margin-bottom: 12px;
    }

    p {
      color: #64748b;
      font-size: 14px;
      line-height: 1.6;
      margin-bottom: 36px;
    }

    .btn-discord {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 14px 24px;
      background: #5865f2;
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.15s;
    }

    .btn-discord:hover {
      background: #4752c4;
      transform: translateY(-2px);
    }

    .error {
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.3);
      border-radius: 8px;
      padding: 12px 16px;
      color: #ef4444;
      font-size: 13px;
      margin-bottom: 20px;
    }
  </style>
</head>
<body>
  <div class="card">
    <img src="/images/dragon-logo.png" alt="Dragon Logo" class="dragon-logo">

    <div class="sub">v0.0.1-beta · Dashboard</div>
    <h1>ModBot Dragon</h1>
    <p>Melde dich mit deinem Discord-Account an, um das Dashboard zu öffnen.</p>

    {error && (
      <div class="error">
        ❌ {error === 'no_code' ? 'Kein Autorisierungscode erhalten.' :
            error === 'oauth_failed' ? 'Discord Login fehlgeschlagen.' :
            'Ein unbekannter Fehler ist aufgetreten.'}
      </div>
    )}

    <a href={oauthUrl} class="btn-discord">
      Mit Discord anmelden
    </a>
  </div>
</body>
</html>