---
import '../styles/global.css';

const API_URL   = import.meta.env.PUBLIC_API_URL   || 'http://localhost:3001';
const API_TOKEN = import.meta.env.PUBLIC_API_TOKEN || '';
const CLIENT_ID = import.meta.env.PUBLIC_DISCORD_CLIENT_ID || '';
const selectedGuild = Astro.cookies.get('selectedGuild')?.value || '';
if (!selectedGuild) return Astro.redirect('/guild');
const GUILD_ID = selectedGuild;

const logConfig = [
  { label: 'Nachrichten gelöscht',   sub: 'MessageDelete',         on: true  },
  { label: 'Nachrichten bearbeitet', sub: 'MessageUpdate',         on: true  },
  { label: 'Bans & Unbans',          sub: 'GuildBanAdd/Remove',    on: true  },
  { label: 'Member Join/Leave',      sub: 'GuildMemberAdd/Remove', on: true  },
  { label: 'Voice State Updates',    sub: 'VoiceStateUpdate',      on: false },
  { label: 'Rollen Änderungen',      sub: 'GuildMemberUpdate',     on: true  },
  { label: 'Channel Änderungen',     sub: 'ChannelUpdate',         on: false },
  { label: 'Emoji Events',           sub: 'GuildEmojiCreate',      on: false },
];
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ModBot Dragon · Dashboard</title>
  <script define:vars={{ apiUrl: API_URL, apiToken: API_TOKEN, clientId: CLIENT_ID, guildId: GUILD_ID }}>
    window.__API_URL__   = apiUrl;
    window.__API_TOKEN__ = apiToken;
    window.__CLIENT_ID__ = clientId;
    window.__GUILD_ID__  = guildId;
  </script>
</head>
<body>

<input type="hidden" id="active-guild" value={GUILD_ID}/>
<div id="toast-container"></div>

<div class="shell">

  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="brand-name"><span class="brand-dot"></span>ModBot Dragon</div>
      <div class="brand-sub">v2.4.1 · Dashboard</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-label">Übersicht</div>
      <a href="#" class="nav-item active" data-section="overview">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="1" y="1" width="6" height="6" rx="1.5"/><rect x="9" y="1" width="6" height="6" rx="1.5"/>
          <rect x="1" y="9" width="6" height="6" rx="1.5"/><rect x="9" y="9" width="6" height="6" rx="1.5"/>
        </svg>Dashboard
      </a>

      <div class="nav-label">Tickets</div>
      <a href="#" class="nav-item" data-section="tickets">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 5a2 2 0 012-2h8a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V5z"/>
          <path d="M5 8h6M5 10.5h4"/>
        </svg>Offene Tickets
      </a>
      <a href="#" class="nav-item" data-section="transcripts">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 1.5h8a1 1 0 011 1v11a1 1 0 01-1 1H4a1 1 0 01-1-1v-11a1 1 0 011-1z"/>
          <path d="M5.5 5.5h5M5.5 8h5M5.5 10.5h3"/>
        </svg>Transcripts
      </a>

      <div class="nav-label">Server</div>
      <a href="#" class="nav-item" data-section="logging">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 4h12M2 8h8M2 12h5"/>
        </svg>Logging
      </a>
      <a href="#" class="nav-item" data-section="commands">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 4l4 4-4 4M9 12h5"/>
        </svg>Commands
      </a>
      <a href="#" class="nav-item" data-section="antinuke">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M8 1.5L2 4v4c0 3.31 2.69 6 6 7.5C14 14 14 12 14 8V4L8 1.5z"/>
        </svg>AntiNuke
      </a>
      <a href="#" class="nav-item" data-section="voice">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5.5 3.5a2.5 2.5 0 015 0v4a2.5 2.5 0 01-5 0v-4z"/>
          <path d="M3 8a5 5 0 0010 0M8 13v2M5 15h6"/>
        </svg>Voice Support
      </a>
      <a href="#" class="nav-item" data-section="invite">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="8" cy="6" r="2.5"/>
          <path d="M3 13c0-2.76 2.24-5 5-5s5 2.24 5 5"/>
          <path d="M12 3l2 2-2 2M14 5H10"/>
        </svg>Bot einladen
      </a>
      <a href="#" class="nav-item" data-section="settings">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="8" cy="8" r="2"/>
          <path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15M3.05 3.05l1.06 1.06M11.89 11.89l1.06 1.06M3.05 12.95l1.06-1.06M11.89 4.11l1.06-1.06"/>
        </svg>Einstellungen
      </a>
    </nav>
    <div class="sidebar-footer">
      <div class="user-pill">
        <div class="user-avatar" id="sidebar-avatar">?</div>
        <div style="flex:1;min-width:0;">
          <div class="user-name" id="sidebar-username">Lädt...</div>
        </div>
        <span class="user-role">ADMIN</span>
      </div>
    </div>
  </aside>

  <!-- Main -->
  <div class="main">
    <header class="topbar">
      <div class="topbar-title">
        Dashboard <span class="topbar-sep">›</span>
        <span class="crumb-active">Übersicht</span>
      </div>
      <div class="topbar-right">
<div class="status-chip" id="bot-status-chip" style="color:var(--text-muted);background:var(--bg-raised);border:1px solid var(--border);">
          ● LÄDT...
        </div>
        <div class="ping-chip" id="ping-display">—</div>
        <button class="btn btn-ghost btn-sm" id="refresh-btn">
          <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" id="refresh-icon">
            <path d="M13.5 8A5.5 5.5 0 112.5 8"/><path d="M13.5 4v4h-4"/>
          </svg>
          Refresh
        </button>
      </div>
    </header>

    <main class="content">

      <!-- ══ OVERVIEW ══ -->
      <div id="overview" class="page-section" style="display:flex;flex-direction:column;gap:28px;">
        <section>
          <div class="section-header">
            <div class="section-title">Bot Statistiken</div>
            <span style="font-family:var(--font-mono);font-size:10px;color:var(--text-muted);">
              Uptime: <span id="uptime-display">—</span>
            </span>
          </div>
          <div class="stats-grid">
            <div class="stat-card animate-fadeUp delay-1">
              <div class="stat-label">Server</div>
              <div class="stat-value" id="stat-guilds">—</div>
              <div class="stat-sub">aktive Guilds</div>
              <div class="stat-icon">🌐</div>
            </div>
            <div class="stat-card animate-fadeUp delay-2">
              <div class="stat-label">Nutzer</div>
              <div class="stat-value" id="stat-users">—</div>
              <div class="stat-sub">gesamt erreichbar</div>
              <div class="stat-icon">👥</div>
            </div>
            <div class="stat-card animate-fadeUp delay-3">
              <div class="stat-label">Ping</div>
              <div class="stat-value blue" id="stat-ping">—</div>
              <div class="stat-sub">WebSocket Latenz</div>
              <div class="stat-icon">📡</div>
            </div>
            <div class="stat-card animate-fadeUp delay-4">
              <div class="stat-label">Tickets offen</div>
              <div class="stat-value blue" id="stat-tickets">—</div>
              <div class="stat-sub" id="stat-tickets-sub">wird geladen...</div>
              <div class="stat-icon">🎫</div>
            </div>
          </div>
        </section>

        <section>
          <div class="section-header"><div class="section-title">Live Status</div></div>
          <div class="card animate-fadeUp">
            <div class="card-head">
              <div class="card-title">⚡ Bot Aktivität</div>
              <div class="status-chip online" id="status-chip-card">● LÄDT...</div>
            </div>
            <div class="pulse-bar" style="padding:14px 18px 0;" id="pulse-bar">
              <!-- Wird via JS befüllt -->
            </div>
            <div class="status-blocks">
              <div class="status-block">
                <div class="status-block-label">Status</div>
                <div class="status-block-value" id="status-value" style="color:var(--text-muted);">LÄDT</div>
              </div>
              <div class="status-block">
                <div class="status-block-label">Latenz</div>
                <div class="status-block-value blue" id="latency-value">—</div>
              </div>
              <div class="status-block">
                <div class="status-block-label">Uptime</div>
                <div class="status-block-value" id="uptime-value">—</div>
              </div>
            </div>
          </div>
        </section>

        <!-- Server-Liste -->
        <section>
          <div class="section-header">
            <div class="section-title">Bot auf diesen Servern</div>
          </div>
          <div class="card animate-fadeUp">
            <div class="card-head">
              <div class="card-title">🌐 Aktive Guilds</div>
              <span class="badge badge-outline" id="guild-count-badge">wird geladen...</span>
            </div>
            <div id="guild-list-container">
              <div style="padding:24px;text-align:center;color:var(--text-muted);font-family:var(--font-mono);font-size:12px;">
                Lade Server...
              </div>
            </div>
          </div>
        </section>

        <!-- Tickets Übersicht -->
        <section>
          <div class="section-header"><div class="section-title">Offene Tickets</div></div>
          <div class="card animate-fadeUp">
            <div class="card-head">
              <div class="card-title">🎫 Aktive Tickets</div>
              <span class="badge badge-outline" id="tickets-badge">wird geladen...</span>
            </div>
            <div class="table-head" style="grid-template-columns:70px 1fr 110px 80px 1fr;">
              <span>#</span><span>User ID</span><span>Kategorie</span><span>Status</span><span>Erstellt</span>
            </div>
            <div id="tickets-body">
              <div style="padding:24px;text-align:center;color:var(--text-muted);font-family:var(--font-mono);font-size:12px;">
                Lade Tickets...
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- ══ TICKETS ══ -->
      <div id="tickets" class="page-section" style="display:none;">
        <div class="section-header">
          <div class="section-title">Offene Tickets</div>
        </div>
        <div class="card">
          <div class="card-head">
            <div class="card-title">🎫 Ticket-Übersicht</div>
            <span class="badge badge-outline" id="tickets-full-badge">—</span>
          </div>
          <div class="table-head" style="grid-template-columns:70px 1fr 110px 1fr;">
            <span>#</span><span>User ID</span><span>Kategorie</span><span>Erstellt</span>
          </div>
          <div id="tickets-full-body">
            <div style="padding:24px;text-align:center;color:var(--text-muted);font-family:var(--font-mono);font-size:12px;">Lade...</div>
          </div>
        </div>
      </div>

      <!-- ══ LOGGING ══ -->
      <div id="logging" class="page-section" style="display:none;">
        <div class="section-header">
          <div class="section-title">Logging Konfiguration</div>
          <button class="btn btn-primary btn-sm" id="save-logging-btn">Speichern</button>
        </div>
        <div class="card">
          <div class="card-head">
            <div class="card-title">⚙️ Event-Logging</div>
            <span class="badge badge-outline">{logConfig.filter(r=>r.on).length} aktiv</span>
          </div>
          <div class="config-grid">
            {logConfig.map(row => (
              <div class="config-row">
                <div>
                  <div class="config-label">{row.label}</div>
                  <div class="config-sub">{row.sub}</div>
                </div>
                <label class="toggle">
                  <input type="checkbox" checked={row.on} data-event={row.sub}/>
                  <div class="toggle-track"></div>
                </label>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- ══ COMMANDS ══ -->
      <div id="commands" class="page-section" style="display:none;">
        <div class="section-header">
          <div class="section-title">Command Konfiguration</div>
        </div>
        <div id="commands-list">
          <div style="padding:24px;text-align:center;color:var(--text-muted);font-family:var(--font-mono);font-size:12px;">
            Lade Commands...
          </div>
        </div>
      </div>

      <!-- ══ INVITE ══ -->
      <div id="invite" class="page-section" style="display:none;">
        <div class="section-header">
          <div class="section-title">Bot einladen</div>
        </div>
        <div class="card" style="max-width:600px;">
          <div class="card-head">
            <div class="card-title">🔗 Einladungslink</div>
          </div>
          <div style="padding:24px;display:flex;flex-direction:column;gap:20px;">
            <p style="font-size:13px;color:var(--text-secondary);line-height:1.7;">
              Mit diesem Link kannst du <strong style="color:var(--text-primary);">ModBot Dragon</strong> auf einen neuen Discord-Server einladen.
              Du benötigst Administrator-Rechte auf dem Ziel-Server.
            </p>

            <div style="background:var(--bg-raised);border:1px solid var(--border);border-radius:8px;padding:14px 16px;display:flex;align-items:center;gap:12px;">
              <div style="font-family:var(--font-mono);font-size:11px;color:var(--text-secondary);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" id="invite-url-display">
                Wird generiert...
              </div>
              <button class="btn btn-ghost btn-sm" id="copy-invite-btn">Kopieren</button>
            </div>

            <a id="invite-link-btn" href="#" target="_blank" class="btn btn-primary" style="align-self:flex-start;">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 3H3a1 1 0 00-1 1v9a1 1 0 001 1h9a1 1 0 001-1V9M10 2h4v4M14 2L8 8"/>
              </svg>
              Bot jetzt einladen
            </a>

            <div style="border-top:1px solid var(--border);padding-top:16px;">
              <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);margin-bottom:12px;">
                Benötigte Berechtigungen
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:6px;">
                {['Administrator', 'Nachrichten lesen', 'Nachrichten senden', 'Channels verwalten',
                  'Rollen verwalten', 'Mitglieder bannen', 'Mitglieder kicken', 'Audit Log lesen',
                  'Embeds senden', 'Dateien anhängen'].map(perm => (
                  <span style="font-family:var(--font-mono);font-size:10px;padding:3px 8px;background:var(--blue-glow);border:1px solid var(--border-accent);border-radius:4px;color:var(--blue);">
                    {perm}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ══ SETTINGS ══ -->
      <div id="settings" class="page-section" style="display:none;">
        <div class="section-header"><div class="section-title">Einstellungen</div></div>
        <div class="two-col">
          <div class="card">
            <div class="card-head"><div class="card-title">🎫 Panel Einstellungen</div></div>
            <form id="panel-form" style="padding:18px;display:flex;flex-direction:column;gap:14px;">
              <div>
                <label class="field-label">Panel Titel</label>
                <input type="text" id="panel-title" class="field-input" placeholder="Support Tickets"/>
              </div>
              <div>
                <label class="field-label">Panel Beschreibung</label>
                <textarea id="panel-description" class="field-input" rows="4" placeholder="Beschreibung..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-sm" style="align-self:flex-start;">Speichern</button>
            </form>
          </div>
          <div class="card">
            <div class="card-head"><div class="card-title">📋 Channel & Rollen IDs</div></div>
            <form id="channel-form" style="padding:18px;display:flex;flex-direction:column;gap:14px;">
              {[
                {id:'log-channel-id',        label:'Log-Channel ID',        ph:'z.B. 1234567890'},
                {id:'transcript-channel-id', label:'Transcript-Channel ID', ph:'z.B. 1234567890'},
                {id:'category-id',           label:'Ticket-Kategorie ID',   ph:'Discord Kategorie ID'},
                {id:'support-role-id',       label:'Globale Support-Rolle', ph:'Rollen ID'},
              ].map(f => (
                <div>
                  <label class="field-label">{f.label}</label>
                  <input type="text" id={f.id} class="field-input field-mono" placeholder={f.ph}/>
                </div>
              ))}
              <button type="submit" class="btn btn-primary btn-sm" style="align-self:flex-start;">Speichern</button>
            </form>
          </div>
        </div>
      </div>


      <!-- ══ ANTINUKE ══ -->
      <div id="antinuke" class="page-section" style="display:none;">
        <div class="section-header">
          <div class="section-title">AntiNuke Konfiguration</div>
        </div>
        <div class="card" style="max-width:700px;">
          <div class="card-head"><div class="card-title">🛡️ Server Schutz</div></div>
          <form id="antinuke-form" style="padding:0;">
            <div class="config-grid">
              <div class="config-row" style="grid-column:1/-1;background:var(--blue-glow);border-color:var(--border-accent);">
                <div>
                  <div class="config-label" style="color:var(--blue);">AntiNuke aktiviert</div>
                  <div class="config-sub">Schutz gegen Server-Angriffe global ein/ausschalten</div>
                </div>
                <label class="toggle"><input type="checkbox" id="antinuke-enabled"/><div class="toggle-track"></div></label>
              </div>
              <div class="config-row">
                <div><div class="config-label">Ban-Schutz</div><div class="config-sub">Massenban erkennen & stoppen</div></div>
                <label class="toggle"><input type="checkbox" id="antinuke-ban"/><div class="toggle-track"></div></label>
              </div>
              <div class="config-row">
                <div><div class="config-label">Kick-Schutz</div><div class="config-sub">Massenkick erkennen & stoppen</div></div>
                <label class="toggle"><input type="checkbox" id="antinuke-kick"/><div class="toggle-track"></div></label>
              </div>
              <div class="config-row">
                <div><div class="config-label">Channel-Schutz</div><div class="config-sub">Massen-Channel-Löschung verhindern</div></div>
                <label class="toggle"><input type="checkbox" id="antinuke-channel-delete"/><div class="toggle-track"></div></label>
              </div>
              <div class="config-row">
                <div><div class="config-label">Rollen-Schutz</div><div class="config-sub">Massen-Rollen-Löschung verhindern</div></div>
                <label class="toggle"><input type="checkbox" id="antinuke-role-delete"/><div class="toggle-track"></div></label>
              </div>
              <div class="config-row" style="grid-column:1/-1;">
                <div><div class="config-label">Webhook-Schutz</div><div class="config-sub">Unberechtigte Webhooks erkennen</div></div>
                <label class="toggle"><input type="checkbox" id="antinuke-webhook"/><div class="toggle-track"></div></label>
              </div>
            </div>
            <div style="padding:16px 18px;border-top:1px solid var(--border);">
              <button type="submit" class="btn btn-primary btn-sm">Speichern</button>
            </div>
          </form>
        </div>
      </div>

      <!-- ══ VOICE ══ -->
      <div id="voice" class="page-section" style="display:none;">
        <div class="section-header">
          <div class="section-title">Voice Support</div>
        </div>
        <div class="card" style="max-width:600px;">
          <div class="card-head"><div class="card-title">🎙️ Voice Support Konfiguration</div></div>
          <form id="voice-form" style="padding:18px;display:flex;flex-direction:column;gap:14px;">
            <div>
              <label class="field-label">Join-Channel (Trigger)</label>
              <select id="voice-channel-select" class="field-input field-mono">
                <option value="">Channel wählen...</option>
              </select>
              <div style="margin-top:6px;"><input type="text" id="voice-channel-id" class="field-input field-mono" placeholder="Oder Channel-ID manuell eingeben"/></div>
            </div>
            <div>
              <label class="field-label">Kategorie für temporäre Channels</label>
              <select id="voice-category-select" class="field-input field-mono">
                <option value="">Kategorie wählen...</option>
              </select>
              <div style="margin-top:6px;"><input type="text" id="voice-category-id" class="field-input field-mono" placeholder="Oder Kategorie-ID manuell eingeben"/></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm" style="align-self:flex-start;">Speichern</button>
          </form>
        </div>
      </div>

      <!-- Placeholder -->
      <div id="transcripts" class="page-section" style="display:none;">
        <div style="display:flex;align-items:center;justify-content:center;min-height:200px;color:var(--text-muted);font-family:var(--font-mono);font-size:12px;flex-direction:column;gap:12px;">
          <span style="font-size:32px;opacity:0.25;">🚧</span>
          <span>/transcripts – Coming soon</span>
        </div>
      </div>

    </main>
  </div>
</div>

<script src="../scripts/dashboard.ts"></script>

<style>
  .field-label {
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-secondary); display: block; margin-bottom: 6px;
  }
  .field-input {
    width: 100%; background: var(--bg-raised);
    border: 1px solid var(--border); border-radius: 6px;
    padding: 9px 12px; color: var(--text-primary);
    font-family: var(--font-sans); font-size: 13px;
    outline: none; transition: border-color 0.15s; resize: vertical;
  }
  .field-input:focus { border-color: var(--border-accent); }
  .field-mono { font-family: var(--font-mono); font-size: 12px; }

  #refresh-btn.spinning #refresh-icon { animation: spin 0.5s linear; }
  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

  .guild-row {
    display: flex; align-items: center; gap: 14px;
    padding: 12px 18px; border-bottom: 1px solid var(--border);
