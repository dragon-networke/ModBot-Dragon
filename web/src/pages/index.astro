---
import '../styles/global.css';

const API_URL   = import.meta.env.PUBLIC_API_URL   || 'http://localhost:3001';
const API_TOKEN = import.meta.env.PUBLIC_API_TOKEN || '';
const CLIENT_ID = import.meta.env.PUBLIC_DISCORD_CLIENT_ID || '';
const selectedGuild = Astro.cookies.get('selectedGuild')?.value || '';
if (!selectedGuild) return Astro.redirect('/guild');
const GUILD_ID = selectedGuild;

// Session für User-Info
const sessionCookie = Astro.cookies.get('session')?.value;
let currentUser = null;
if (sessionCookie) {
  try {
    const data = JSON.parse(Buffer.from(sessionCookie, 'base64').toString('utf-8'));
    currentUser = data.user;
  } catch (e) {
    console.error('[Dashboard] Session parsing failed');
  }
}

const logConfig = [
  { label: 'Nachrichten gelöscht',   sub: 'MessageDelete',         on: true  },
  { label: 'Nachrichten bearbeitet', sub: 'MessageUpdate',         on: true  },
  { label: 'Bans & Unbans',          sub: 'GuildBanAdd/Remove',    on: true  },
  { label: 'Member Join/Leave',      sub: 'GuildMemberAdd/Remove', on: true  },
  { label: 'Voice State Updates',    sub: 'VoiceStateUpdate',      on: false },
  { label: 'Rollen Änderungen',      sub: 'GuildMemberUpdate',     on: true  },
  { label: 'Channel Änderungen',     sub: 'ChannelUpdate',         on: false },
  { label: 'Emoji Events',           sub: 'GuildEmojiCreate',      on: false },
];
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ModBot Dragon · Dashboard</title>
  <script define:vars={{ apiUrl: API_URL, apiToken: API_TOKEN, clientId: CLIENT_ID, guildId: GUILD_ID }}>
    window.__API_URL__   = apiUrl;
    window.__API_TOKEN__ = apiToken;
    window.__CLIENT_ID__ = clientId;
    window.__GUILD_ID__  = guildId;
  </script>
</head>
<body>

<input type="hidden" id="active-guild" value={GUILD_ID}/>
<div id="toast-container"></div>

<div class="shell">

  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="brand-name"><span class="brand-dot"></span>ModBot Dragon</div>
      <div class="brand-sub">v2.4.1 · Dashboard</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-label">Übersicht</div>
      <a href="#" class="nav-item active" data-section="overview">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="1" y="1" width="6" height="6" rx="1.5"/><rect x="9" y="1" width="6" height="6" rx="1.5"/>
          <rect x="1" y="9" width="6" height="6" rx="1.5"/><rect x="9" y="9" width="6" height="6" rx="1.5"/>
        </svg>Dashboard
      </a>

      <div class="nav-label">Tickets</div>
      <a href="#" class="nav-item" data-section="tickets">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 5a2 2 0 012-2h8a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V5z"/>
          <path d="M5 8h6M5 10.5h4"/>
        </svg>Offene Tickets
      </a>
      <a href="#" class="nav-item" data-section="transcripts">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 1.5h8a1 1 0 011 1v11a1 1 0 01-1 1H4a1 1 0 01-1-1v-11a1 1 0 011-1z"/>
          <path d="M5.5 5.5h5M5.5 8h5M5.5 10.5h3"/>
        </svg>Transcripts
      </a>

      <div class="nav-label">Server</div>
      <a href="#" class="nav-item" data-section="logging">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 4h12M2 8h8M2 12h5"/>
        </svg>Logging
      </a>
      <a href="#" class="nav-item" data-section="commands">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 4l4 4-4 4M9 12h5"/>
        </svg>Commands
      </a>
      <a href="#" class="nav-item" data-section="antinuke">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M8 1.5L2 4v4c0 3.31 2.69 6 6 7.5C14 14 14 12 14 8V4L8 1.5z"/>
        </svg>AntiNuke
      </a>
      <a href="#" class="nav-item" data-section="voice">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5.5 3.5a2.5 2.5 0 015 0v4a2.5 2.5 0 01-5 0v-4z"/>
          <path d="M3 8a5 5 0 0010 0M8 13v2M5 15h6"/>
        </svg>Voice Support
      </a>
      <a href="#" class="nav-item" data-section="invite">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="8" cy="6" r="2.5"/>
          <path d="M3 13c0-2.76 2.24-5 5-5s5 2.24 5 5"/>
          <path d="M12 3l2 2-2 2M14 5H10"/>
        </svg>Bot einladen
      </a>
      <a href="#" class="nav-item" data-section="settings">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="8" cy="8" r="2"/>
          <path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15M3.05 3.05l1.06 1.06M11.89 11.89l1.06 1.06M3.05 12.95l1.06-1.06M11.89 4.11l1.06-1.06"/>
        </svg>Einstellungen
      </a>
    </nav>

    <!-- Sidebar Footer mit Impressum & Datenschutz -->
    <div class="sidebar-footer">
      <div class="flex flex-col gap-4 pt-6 border-t border-zinc-800">

        <!-- Angemeldeter User -->
        {currentUser && (
          <div class="flex items-center gap-3 px-3 py-2 bg-zinc-900/50 rounded-xl">
            <img 
              src={`https://cdn.discordapp.com/avatars/${currentUser.id}/${currentUser.avatar}.png?size=48`}
              alt={currentUser.username}
              class="w-8 h-8 rounded-full ring-2 ring-zinc-700"
              onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
            >
            <div class="text-sm">
              <div class="font-medium text-white">{currentUser.username}</div>
              <div class="text-emerald-400 text-xs">angemeldet</div>
            </div>
          </div>
        )}

        <!-- Rechts-Links -->
        <div class="flex flex-col gap-1 text-xs px-3">
          <a href="/impressum" 
             class="text-zinc-400 hover:text-zinc-200 transition-colors flex items-center gap-2 py-1">
            📜 Impressum
          </a>
          <a href="/datenschutz" 
             class="text-zinc-400 hover:text-zinc-200 transition-colors flex items-center gap-2 py-1">
            🔒 Datenschutz
          </a>
        </div>

        <div class="text-[10px] text-zinc-600 px-3 mt-4">
          ModBot Dragon Dashboard © 2026
        </div>
      </div>
    </div>
  </aside>

  <!-- Main -->
  <div class="main">
    <header class="topbar">
      <div class="topbar-title">
        Dashboard <span class="topbar-sep">›</span>
        <span class="crumb-active">Übersicht</span>
      </div>

      <div class="topbar-right">
        {currentUser ? (
          <div class="user-menu flex items-center gap-3 bg-zinc-900 border border-zinc-700 rounded-2xl px-5 py-2.5">
            <img 
              src={`https://cdn.discordapp.com/avatars/${currentUser.id}/${currentUser.avatar}.png?size=64`}
              alt={currentUser.username}
              class="w-9 h-9 rounded-full ring-2 ring-zinc-600 object-cover"
              onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
            />
            <div class="text-left min-w-0">
              <div class="text-sm font-semibold text-white truncate">
                {currentUser.username}
              </div>
              <div class="text-[10px] text-emerald-400 font-mono tracking-wider">ANGEMELDET</div>
            </div>
            <a href="/auth/logout"
               class="ml-2 flex h-8 w-8 items-center justify-center text-red-400 hover:text-red-300 hover:bg-zinc-800 rounded-xl transition-all"
               title="Abmelden">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4V7m-4 4V7" />
              </svg>
            </a>
          </div>
        ) : (
          <a href="/login" class="text-sm text-zinc-400 hover:text-white px-4 py-2">Anmelden</a>
        )}

        <div class="status-chip" id="bot-status-chip">● LÄDT...</div>
        <div class="ping-chip" id="ping-display">—</div>
        <button class="btn btn-ghost btn-sm" id="refresh-btn">
          <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" id="refresh-icon">
            <path d="M13.5 8A5.5 5.5 0 112.5 8"/><path d="M13.5 4v4h-4"/>
          </svg>
          Refresh
        </button>
      </div>
    </header>

    <main class="content">
      <!-- Hier kommt dein kompletter alter Content rein (Overview, Tickets, Logging usw.) -->
      <!-- Kopiere einfach alles ab <div id="overview" ...> bis zum Ende deines alten <main> hier hinein -->
      
      <!-- Beispiel: Dein Overview-Bereich bleibt gleich -->
      <div id="overview" class="page-section" style="display:flex;flex-direction:column;gap:28px;">
        <!-- ... dein ganzer alter Content ... -->
      </div>

      <!-- Die anderen Sections (tickets, logging, commands, invite, settings, antinuke, voice, transcripts) ebenfalls unverändert -->
    </main>
  </div>
</div>

<script src="../scripts/dashboard.ts"></script>

<style>
  /* Deine bisherigen Styles bleiben gleich */
  .field-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-secondary); display: block; margin-bottom: 6px; }
  .field-input { width: 100%; background: var(--bg-raised); border: 1px solid var(--border); border-radius: 6px; padding: 9px 12px; color: var(--text-primary); font-family: var(--font-sans); font-size: 13px; outline: none; transition: border-color 0.15s; resize: vertical; }
  .field-input:focus { border-color: var(--border-accent); }
  .field-mono { font-family: var(--font-mono); font-size: 12px; }

  #refresh-btn.spinning #refresh-icon { animation: spin 0.5s linear; }
  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

  .user-menu {
    transition: all 0.2s;
  }
  .user-menu:hover {
    border-color: #3b82f6;
  }
</style>
</body>
</html>