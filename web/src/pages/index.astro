---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ModBot Dragon · Dashboard" pageTitle="Übersicht">
  <div class="main">
    <header class="topbar">
      <div class="topbar-title">Dashboard <span class="topbar-sep">›</span> <span class="crumb-active">Übersicht</span></div>
      <div class="topbar-right">
        <button class="btn btn-ghost btn-sm" id="refresh-btn">Refresh</button>
      </div>
    </header>

    <main class="content">
      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon">🌐</div>
          <div class="stat-value" id="stat-guilds">—</div>
          <div class="stat-label">Server</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">👥</div>
          <div class="stat-value" id="stat-users">—</div>
          <div class="stat-label">Nutzer</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">⚡</div>
          <div class="stat-value" id="stat-ping">—</div>
          <div class="stat-label">Ping</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🎫</div>
          <div class="stat-value" id="stat-tickets">—</div>
          <div class="stat-label">Offene Tickets</div>
        </div>
      </div>

      <!-- Live Status -->
      <div class="card">
        <div class="card-header">
          <div>LIVE STATUS</div>
          <div class="status-chip" id="bot-status-chip">● LÄDT...</div>
        </div>
        <div class="live-stats">
          <div>STATUS <span id="bot-status">LÄDT</span></div>
          <div>LATENZ <span id="bot-ping">—</span></div>
          <div>UPTIME <span id="bot-uptime">—</span></div>
        </div>
      </div>

      <!-- Server Liste -->
      <div class="card">
        <div class="card-header">
          <div>Server Liste</div>
        </div>
        <div id="guild-list-container" class="guild-list">
          Lade Server...
        </div>
      </div>

      <!-- Offene Tickets -->
      <div class="card">
        <div class="card-header">
          <div>OFFENE TICKETS</div>
        </div>
        <div id="tickets-body" class="tickets-table">
          Lade Tickets...
        </div>
      </div>
    </main>
  </div>
</Layout>