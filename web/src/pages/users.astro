---
import '../styles/global.css';

const session     = Astro.cookies.get('session')?.value;
const sessionData = session ? JSON.parse(Buffer.from(session, 'base64').toString('utf-8')) : null;
const user        = sessionData?.user;
const guildId     = Astro.cookies.get('selectedGuild')?.value || '';

const API_URL   = import.meta.env.PUBLIC_API_URL   || 'http://localhost:3001';
const API_TOKEN = import.meta.env.PUBLIC_API_TOKEN || '';
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ModBot Dragon · Nutzerverwaltung</title>
  <script define:vars={{ apiUrl: API_URL, apiToken: API_TOKEN, guildId }}>
    window.__API_URL__   = apiUrl;
    window.__API_TOKEN__ = apiToken;
    window.__GUILD_ID__  = guildId;
  </script>
</head>
<body>
<div class="shell">
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="brand-name"><span class="brand-dot"></span>ModBot Dragon</div>
      <div class="brand-sub">Nutzerverwaltung</div>
    </div>
    <nav class="sidebar-nav">
      <a href="/"            class="nav-item">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="1" y="1" width="6" height="6" rx="1.5"/><rect x="9" y="1" width="6" height="6" rx="1.5"/>
          <rect x="1" y="9" width="6" height="6" rx="1.5"/><rect x="9" y="9" width="6" height="6" rx="1.5"/>
        </svg>Dashboard
      </a>
      <a href="/transcripts" class="nav-item">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 1.5h8a1 1 0 011 1v11a1 1 0 01-1 1H4a1 1 0 01-1-1v-11a1 1 0 011-1z"/>
          <path d="M5.5 5.5h5M5.5 8h5M5.5 10.5h3"/>
        </svg>Transcripts
      </a>
      <a href="/users"       class="nav-item active">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="6" cy="5" r="2.5"/><path d="M1 13c0-2.76 2.24-5 5-5s5 2.24 5 5"/>
          <path d="M11 7l1.5 1.5L15 6"/>
        </svg>Nutzer
      </a>
      <a href="/settings"    class="nav-item">
        <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="8" cy="8" r="2"/>
          <path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15"/>
        </svg>Einstellungen
      </a>
    </nav>
    <div class="sidebar-footer">
      <div class="user-pill">
        <div class="user-avatar">{user?.username?.[0]?.toUpperCase() ?? '?'}</div>
        <div class="user-name">{user?.username ?? '—'}</div>
        <a href="/auth/logout" style="font-family:var(--font-mono);font-size:9px;color:var(--text-muted);text-decoration:none;margin-left:auto;" title="Logout">↩</a>
      </div>
    </div>
  </aside>

  <div class="main">
    <header class="topbar">
      <div class="topbar-title">Dashboard <span class="topbar-sep">›</span> <span class="crumb-active">Nutzerverwaltung</span></div>
      <div class="topbar-right">
        <button class="btn btn-ghost btn-sm" id="refresh-btn">
          <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" id="refresh-icon">
            <path d="M13.5 8A5.5 5.5 0 112.5 8"/><path d="M13.5 4v4h-4"/>
          </svg>Refresh
        </button>
      </div>
    </header>

    <main class="content">
      <div style="display:flex;flex-direction:column;gap:28px;">

        <!-- Nutzer suchen -->
        <section>
          <div class="section-header">
            <div class="section-title">Nutzer suchen</div>
          </div>
          <div class="card">
            <div class="card-head"><div class="card-title">🔍 Nutzer nachschlagen</div></div>
            <div style="padding:18px;display:flex;gap:10px;">
              <input type="text" id="user-search" class="field-input field-mono" placeholder="User ID oder Username eingeben..." style="flex:1;"/>
              <button class="btn btn-primary" onclick="searchUser()">Suchen</button>
            </div>
            <div id="user-result" style="display:none;padding:0 18px 18px;"></div>
          </div>
        </section>

        <!-- Aktionen -->
        <div class="two-col">

          <!-- Ban/Kick -->
          <div class="card">
            <div class="card-head"><div class="card-title">🔨 Ban / Kick</div></div>
            <div style="padding:18px;display:flex;flex-direction:column;gap:14px;">
              <div>
                <label class="field-label">User ID</label>
                <input type="text" id="action-user-id" class="field-input field-mono" placeholder="User ID..."/>
              </div>
              <div>
                <label class="field-label">Grund</label>
                <input type="text" id="action-reason" class="field-input" placeholder="Grund der Maßnahme..."/>
              </div>
              <div style="display:flex;gap:8px;">
                <button class="btn btn-danger" style="flex:1;" onclick="doAction('ban')">🔨 Bannen</button>
                <button class="btn btn-ghost"  style="flex:1;border-color:rgba(249,115,22,0.3);color:#f97316;" onclick="doAction('kick')">👢 Kicken</button>
              </div>
            </div>
          </div>

          <!-- Rolle vergeben -->
          <div class="card">
            <div class="card-head"><div class="card-title">🎭 Rolle vergeben</div></div>
            <div style="padding:18px;display:flex;flex-direction:column;gap:14px;">
              <div>
                <label class="field-label">User ID</label>
                <input type="text" id="role-user-id" class="field-input field-mono" placeholder="User ID..."/>
              </div>
              <div>
                <label class="field-label">Rolle</label>
                <select id="role-select" class="field-input field-mono">
                  <option value="">Rolle wählen...</option>
                </select>
              </div>
              <div style="display:flex;gap:8px;">
                <button class="btn btn-primary" style="flex:1;" onclick="doRole('add')">+ Hinzufügen</button>
                <button class="btn btn-ghost"   style="flex:1;" onclick="doRole('remove')">− Entfernen</button>
              </div>
            </div>
          </div>

        </div>

        <!-- Mitgliederliste -->
        <section>
          <div class="section-header">
            <div class="section-title">Server Mitglieder</div>
            <span class="badge badge-outline" id="members-count">wird geladen...</span>
          </div>
          <div class="card">
            <div class="card-head">
              <div class="card-title">👥 Mitglieder</div>
              <input type="text" id="member-filter" class="field-input field-mono" placeholder="Filtern..." style="width:180px;"/>
            </div>
            <div class="table-head" style="grid-template-columns:1fr 120px 1fr 100px;">
              <span>User</span><span>ID</span><span>Rollen</span><span>Aktionen</span>
            </div>
            <div id="members-body">
              <div style="padding:32px;text-align:center;color:var(--text-muted);font-family:var(--font-mono);font-size:12px;">Lade Mitglieder...</div>
            </div>
          </div>
        </section>

      </div>
    </main>
  </div>
</div>
<div id="toast-container"></div>

<script>
declare const window: any;

const API   = () => window.__API_URL__   || 'http://localhost:3001';
const TOKEN = () => window.__API_TOKEN__ || '';
const GUILD = () => window.__GUILD_ID__  || '';

async function apiFetch(method: string, path: string, body?: any) {
  const res = await fetch(`${API()}${path}`, {
    method,
    headers: { Authorization: `Bearer ${TOKEN()}`, 'Content-Type': 'application/json' },
    body: body ? JSON.stringify(body) : undefined,
  });
  const data = await res.json().catch(() => ({}));
  if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
  return data;
}

function toast(msg: string, type = 'info') {
  const wrap = document.getElementById('toast-container');
  if (!wrap) return;
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<span>${{success:'✅',error:'❌',info:'ℹ️'}[type]}</span><span>${msg}</span>`;
  wrap.appendChild(el);
  setTimeout(() => { el.style.animation='toastOut 0.2s ease forwards'; setTimeout(()=>el.remove(),200); }, 3000);
}

let allMembers: any[] = [];

// ── Mitglieder laden ──────────────────────────────────────────────────────

async function loadMembers() {
  try {
    const data = await apiFetch('GET', `/api/guild/${GUILD()}/members`);
    allMembers = Array.isArray(data) ? data : [];

    const badge = document.getElementById('members-count');
    if (badge) badge.textContent = `${allMembers.length} Mitglieder`;

    renderMembers(allMembers);
  } catch (e: any) {
    document.getElementById('members-body')!.innerHTML =
      `<div style="padding:24px;text-align:center;color:var(--red);font-family:var(--font-mono);font-size:12px;">${e.message}</div>`;
  }
}

function renderMembers(members: any[]) {
  const body = document.getElementById('members-body')!;
  if (!members.length) {
    body.innerHTML = `<div style="padding:32px;text-align:center;color:var(--text-muted);font-family:var(--font-mono);font-size:12px;">Keine Mitglieder gefunden</div>`;
    return;
  }

  body.innerHTML = members.slice(0, 50).map((m: any) => `
    <div class="table-row" style="grid-template-columns:1fr 120px 1fr 100px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:28px;height:28px;border-radius:50%;background:var(--bg-raised);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;overflow:hidden;">
          ${m.avatar ? `<img src="${m.avatar}" style="width:100%;height:100%;object-fit:cover;"/>` : (m.username||'?')[0].toUpperCase()}
        </div>
        <span class="table-user">${m.username || 'Unbekannt'}${m.nickname ? ` <span style="color:var(--text-muted);font-size:11px;">(${m.nickname})</span>` : ''}</span>
      </div>
      <span class="table-id">${m.id}</span>
      <span style="font-size:11px;color:var(--text-secondary);">${(m.roles||[]).slice(0,3).join(', ')}</span>
      <div style="display:flex;gap:4px;">
        <button class="btn btn-ghost btn-sm" onclick="quickAction('kick','${m.id}')" title="Kicken">👢</button>
        <button class="btn btn-danger btn-sm" onclick="quickAction('ban','${m.id}')" title="Bannen">🔨</button>
      </div>
    </div>
  `).join('');
}

// ── Nutzer suchen ─────────────────────────────────────────────────────────

(window as any).searchUser = async () => {
  const query  = (document.getElementById('user-search') as HTMLInputElement).value.trim();
  const result = document.getElementById('user-result')!;
  if (!query) return;

  result.style.display = 'block';
  result.innerHTML = '<div style="color:var(--text-muted);font-size:13px;">Suche...</div>';

  try {
    const user = await apiFetch('GET', `/api/guild/${GUILD()}/member/${query}`);
    result.innerHTML = `
      <div style="background:var(--bg-raised);border-radius:10px;padding:16px;display:flex;align-items:center;gap:16px;">
        <div style="width:52px;height:52px;border-radius:50%;overflow:hidden;background:var(--bg-hover);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;">
          ${user.avatar ? `<img src="${user.avatar}" style="width:100%;height:100%;object-fit:cover;"/>` : (user.username||'?')[0].toUpperCase()}
        </div>
        <div style="flex:1;">
          <div style="font-weight:700;font-size:15px;">${user.username || 'Unbekannt'}${user.nickname ? ` <span style="color:var(--text-muted);font-size:12px;">(${user.nickname})</span>` : ''}</div>
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted);margin-top:2px;">${user.id}</div>
          <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:4px;">
            ${(user.roles||[]).map((r: string) => `<span style="font-family:var(--font-mono);font-size:10px;padding:2px 7px;background:var(--blue-glow);border:1px solid var(--border-accent);border-radius:3px;color:var(--blue);">${r}</span>`).join('')}
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          <button class="btn btn-ghost btn-sm" onclick="document.getElementById('action-user-id').value='${user.id}'">Aktionen →</button>
        </div>
      </div>
    `;
  } catch (e: any) {
    result.innerHTML = `<div style="color:var(--red);font-size:13px;">❌ ${e.message}</div>`;
  }
};

// ── Ban / Kick ─────────────────────────────────────────────────────────────

(window as any).doAction = async (action: string) => {
  const userId = (document.getElementById('action-user-id') as HTMLInputElement).value.trim();
  const reason = (document.getElementById('action-reason') as HTMLInputElement).value.trim();
  if (!userId) return toast('Bitte eine User ID eingeben', 'error');

  if (!confirm(`Möchtest du den Nutzer wirklich ${action === 'ban' ? 'bannen' : 'kicken'}?`)) return;

  try {
    await apiFetch('POST', `/api/guild/${GUILD()}/member/${userId}/${action}`, { reason: reason || 'Kein Grund angegeben' });
    toast(`Nutzer wurde ${action === 'ban' ? 'gebannt' : 'gekickt'}!`, 'success');
    (document.getElementById('action-user-id') as HTMLInputElement).value = '';
    (document.getElementById('action-reason') as HTMLInputElement).value  = '';
    loadMembers();
  } catch (e: any) { toast(e.message, 'error'); }
};

(window as any).quickAction = async (action: string, userId: string) => {
  if (!confirm(`Nutzer wirklich ${action === 'ban' ? 'bannen' : 'kicken'}?`)) return;
  try {
    await apiFetch('POST', `/api/guild/${GUILD()}/member/${userId}/${action}`, { reason: 'Dashboard Aktion' });
    toast(`Nutzer ${action === 'ban' ? 'gebannt' : 'gekickt'}!`, 'success');
    loadMembers();
  } catch (e: any) { toast(e.message, 'error'); }
};

// ── Rolle vergeben ─────────────────────────────────────────────────────────

(window as any).doRole = async (action: string) => {
  const userId = (document.getElementById('role-user-id') as HTMLInputElement).value.trim();
  const roleId = (document.getElementById('role-select') as HTMLSelectElement).value;
  if (!userId || !roleId) return toast('Bitte User ID und Rolle auswählen', 'error');

  try {
    await apiFetch('POST', `/api/guild/${GUILD()}/member/${userId}/role`, { roleId, action });
    toast(`Rolle ${action === 'add' ? 'hinzugefügt' : 'entfernt'}!`, 'success');
  } catch (e: any) { toast(e.message, 'error'); }
};

// ── Rollen für Dropdown laden ──────────────────────────────────────────────

async function loadRoles() {
  try {
    const roles = await apiFetch('GET', `/api/guild/${GUILD()}/roles`);
    const sel   = document.getElementById('role-select') as HTMLSelectElement;
    sel.innerHTML = '<option value="">Rolle wählen...</option>' +
      roles.map((r: any) => `<option value="${r.id}">${r.name}</option>`).join('');
  } catch { /* ignore */ }
}

// ── Filter ────────────────────────────────────────────────────────────────

document.getElementById('member-filter')?.addEventListener('input', (e) => {
  const q = (e.target as HTMLInputElement).value.toLowerCase();
  renderMembers(allMembers.filter(m =>
    m.username?.toLowerCase().includes(q) ||
    m.id?.includes(q) ||
    m.nickname?.toLowerCase().includes(q)
  ));
});

document.getElementById('refresh-btn')?.addEventListener('click', () => { loadMembers(); loadRoles(); });

document.addEventListener('DOMContentLoaded', () => { loadMembers(); loadRoles(); });
</script>
</body>
</html>
