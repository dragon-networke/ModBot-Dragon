---
import Layout from '../layouts/Layout.astro';
import "../styles/users.css";
---

<Layout title="ModBot Dragon · Nutzer" pageTitle="Nutzer">
  <div class="main">
    <header class="topbar">
      <div class="topbar-title">Dashboard <span class="topbar-sep">›</span> <span class="crumb-active">Nutzer</span></div>
    </header>

    <main class="content">
      <div class="card">
        <div class="card-header">
          <div>Server Mitglieder</div>
        </div>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Avatar</th>
                <th>Username</th>
                <th>User ID</th>
                <th>Rollen</th>
              </tr>
            </thead>
            <tbody id="users-body">
              Lade Nutzer...
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</Layout>