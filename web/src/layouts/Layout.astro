---
import '../styles/global.css';

const { title = 'ModBot Dragon', pageTitle = 'Dashboard' } = Astro.props;

// Session aus Cookie lesen
const sessionCookie = Astro.cookies.get('session')?.value;
let currentUser = null;
if (sessionCookie) {
  try {
    const data = JSON.parse(Buffer.from(sessionCookie, 'base64').toString('utf-8'));
    currentUser = data.user;
  } catch (e) {
    console.error('Session parsing failed in Layout');
  }
}

const guildId = Astro.cookies.get('selectedGuild')?.value || '';
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>

  <script define:vars={{ 
    apiUrl: import.meta.env.PUBLIC_API_URL || 'http://localhost:3001',
    apiToken: import.meta.env.PUBLIC_API_TOKEN || '',
    guildId: guildId
  }}>
    window.__API_URL__   = apiUrl;
    window.__API_TOKEN__ = apiToken;
    window.__GUILD_ID__  = guildId;
  </script>
</head>
<body>
<div class="shell">

  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="brand-name"><span class="brand-dot"></span>ModBot Dragon</div>
      <div class="brand-sub">{pageTitle}</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-label">Übersicht</div>
      <a href="/" class="nav-item {Astro.url.pathname === '/' ? 'active' : ''}">Dashboard</a>
      <a href="/transcripts" class="nav-item {Astro.url.pathname === '/transcripts' ? 'active' : ''}">Transcripts</a>

      <div class="nav-label">Server</div>
      <a href="/guild" class="nav-item {Astro.url.pathname === '/guild' ? 'active' : ''}">Server wechseln</a>
      <a href="/commands" class="nav-item {Astro.url.pathname === '/commands' ? 'active' : ''}">Commands</a>
      <a href="/settings" class="nav-item {Astro.url.pathname === '/settings' ? 'active' : ''}">Einstellungen</a>
    </nav>

    <!-- Footer mit User + Logout -->
    <div class="sidebar-footer">
      <div class="flex flex-col gap-4 pt-6 border-t border-zinc-800">

        {currentUser && (
          <div class="flex items-center gap-3 px-3 py-2 bg-zinc-900/50 rounded-xl">
            <img 
              src={`https://cdn.discordapp.com/avatars/${currentUser.id}/${currentUser.avatar}.png?size=48`}
              alt={currentUser.username}
              class="w-8 h-8 rounded-full ring-2 ring-zinc-700"
              onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
            >
            <div class="text-sm flex-1">
              <div class="font-medium text-white">{currentUser.username}</div>
              <div class="text-emerald-400 text-xs">angemeldet</div>
            </div>
            <!-- Logout als Link zur dedizierten Logout-Seite -->
            <a href="/auth/logout" class="logout-btn">Abmelden</a>
          </div>
        )}

        <div class="flex flex-col gap-1 text-xs px-3">
          <a href="/impressum" class="text-zinc-400 hover:text-zinc-200">📜 Impressum</a>
          <a href="/datenschutz" class="text-zinc-400 hover:text-zinc-200">🔒 Datenschutz</a>
        </div>
      </div>
    </div>
  </aside>

  <slot />

</div>

<div id="toast-container"></div>

<script src="../scripts/dashboard.ts"></script>
</body>
</html>